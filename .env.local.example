# Copia este archivo a .env.local y rellena los valores.
# .env.local y .env NUNCA se commitean (están en .gitignore).

# --- Base de datos (PostgreSQL, Prisma) ---
# Desde el HOST (npm run dev, prisma CLI) usa el puerto publicado (p. ej. 5433):
DATABASE_URL="postgresql://usuario:password@localhost:5433/master_db"
# Dentro de Docker (red compartida) la app usa el puerto interno:
#   postgresql://usuario:password@postgres-db:5432/master_db  (ver docker-compose.yml)

# --- Sesión (login) ---
# Genera uno fuerte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# --- Variables usadas por docker-compose.yml (van en .env, no en .env.local) ---
# DB_USER="admin"
# DB_PASSWORD=""
# DB_NAME="master_db"

# --- SMTP (herramienta de correos) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Lab <no-reply@ejemplo.com>"

# --- Scheduler ---
CRON_SECRET=""
