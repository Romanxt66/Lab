# Copia este archivo a .env.local y rellena los valores.
# .env.local y .env NUNCA se commitean (están en .gitignore).

# --- Base de datos (PostgreSQL, Prisma) ---
# IMPORTANTE: incluye SIEMPRE ?schema=lab (un esquema dedicado). Así Prisma solo
# gestiona las tablas del Lab y NUNCA toca las de otros proyectos en `public`.
# Desde el HOST (npm run dev, prisma CLI) usa el puerto publicado (p. ej. 5433):
DATABASE_URL="postgresql://usuario:password@localhost:5433/master_db?schema=lab"
# Dentro de Docker (red compartida) la app usa el puerto interno:
#   postgresql://usuario:password@postgres-db:5432/master_db?schema=lab

# --- Sesión (login) ---
# Genera uno fuerte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# --- Variables usadas por docker-compose.yml (van en .env, no en .env.local) ---
# DB_USER="admin"
# DB_PASSWORD=""
# DB_NAME="master_db"

# --- SMTP (herramienta de correos, opción clásica) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Lab <no-reply@ejemplo.com>"

# --- Google OAuth (para enviar correos desde tu cuenta Gmail con un botón) ---
# 1) Ve a https://console.cloud.google.com/apis/credentials
# 2) Crea un OAuth 2.0 Client ID de tipo "Web application"
# 3) En "Authorized redirect URIs" añade EXACTAMENTE:
#    https://tu-dominio.com/api/auth/google/callback   (producción)
#    http://localhost:3000/api/auth/google/callback    (desarrollo)
# 4) Habilita la API "Gmail API" en el mismo proyecto.
# 5) Pega el client ID y secret aquí, y el redirect URI que uses en cada entorno.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# --- Scheduler ---
CRON_SECRET=""
