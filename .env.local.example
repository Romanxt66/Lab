# Copia este archivo a .env.local y rellena los valores.
# .env.local NUNCA se commitea (está en .gitignore).

# --- Base de datos (Prisma) ---
# Local: SQLite. En producción cambia a una URL de Postgres.
DATABASE_URL="file:./dev.db"

# --- SMTP (herramienta de correos) ---
# Ej. Gmail: host smtp.gmail.com, port 465, user tu correo, pass app-password.
# Para pruebas puedes usar Mailtrap (https://mailtrap.io).
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Lab <no-reply@ejemplo.com>"

# --- Scheduler ---
# Secreto que protege el endpoint /api/cron cuando se despliega online.
CRON_SECRET=""
