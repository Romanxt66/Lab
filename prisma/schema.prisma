// Prisma schema — persistence layer (an infrastructure detail).
// Client is generated into src/generated/prisma (see .gitignore).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (for the CLI) and is
  // supplied to PrismaClient at runtime via a driver adapter (see shared/db.ts).
}

// NOTE: this schema targets a SHARED database that already contains another
// project's tables. Every Lab-owned table is namespaced via @@map so it can't
// collide: `calendario` and `usuarioslab` as requested, and `lab_*` for the
// rest. Use `prisma db push` (never `migrate`) so existing tables are untouched.

/// Reusable email template with `{{variable}}` placeholders.
model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lab_email_template")
}

/// Google account connected via OAuth to send email as that user via Gmail.
/// Stores the long-lived refresh_token; access tokens are minted on demand.
model GoogleAccount {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  picture      String?
  refreshToken String
  accessToken  String?
  expiresAt    DateTime?
  scope        String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("lab_google_account")
}

/// History of every email send attempt.
model EmailLog {
  id      String   @id @default(uuid())
  to      String
  subject String
  status  String // "sent" | "failed"
  error   String?
  sentAt  DateTime @default(now())

  @@map("lab_email_log")
}

/// A cron-scheduled task that runs an action ("email" | "scrape").
model ScheduledJob {
  id        String   @id @default(uuid())
  name      String
  cron      String // 5-field cron expression
  action    String // "email" | "scrape"
  params    String // JSON payload for the action
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  runs      JobRun[]

  @@map("lab_scheduled_job")
}

/// Result of one execution of a ScheduledJob.
model JobRun {
  id        String       @id @default(uuid())
  jobId     String
  job       ScheduledJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String // "success" | "error"
  output    String?
  startedAt DateTime     @default(now())

  @@map("lab_job_run")
}

/// Lab users (separate table so it won't collide with the other project's
/// tables in the shared database). Mapped to `usuarioslab`.
model UsuariosLab {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         String     @default("user") // "user" | "superadmin"
  createdAt    DateTime   @default(now())
  eventos      Calendario[]

  @@map("usuarioslab")
}

/// Calendar events. Mapped to `calendario`.
model Calendario {
  id                  String       @id @default(uuid())
  title               String
  description         String?
  start               DateTime
  end                 DateTime?
  allDay              Boolean      @default(false)
  location            String?
  color               String? // optional accent tag
  /// Minutes before `start` to send a WhatsApp reminder. null = no reminder.
  remindMinutesBefore Int?
  /// Set once the reminder has been sent, to avoid duplicates.
  reminderSentAt      DateTime?
  userId              String?
  user                UsuariosLab? @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([start])
  @@map("calendario")
}

/// Notification channel config. Only one active row at a time is expected;
/// the calendar reminder job sends to whichever row has `active = true`.
/// `provider` decides how `recipient` and `credential` are interpreted:
///   - telegram: recipient = chat_id, credential = bot_token
model NotificationConfig {
  id         String   @id @default(uuid())
  provider   String   @default("telegram")
  recipient  String
  credential String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("lab_notification_config")
}
